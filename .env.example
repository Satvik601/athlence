# ATHLENCE — Environment variables
# Brief §12 + §13 — All third-party integrations and CMS keys.
#
# Copy to .env.local for development. Production lives in Vercel project env.
# Every integration has a graceful fallback — the site renders fully with ZERO
# env vars set. These unlock real functionality (live IG feed, working signup,
# real analytics, etc.), not visual completeness.

# ───────────────────────────────────────────────────────────────────────────
# Core
# ───────────────────────────────────────────────────────────────────────────
SITE_URL=http://localhost:3000
# In production: SITE_URL=https://athlence.com

# ───────────────────────────────────────────────────────────────────────────
# Sanity CMS  (Brief §13)
# Every editable string lives here. Without these, fallback content renders
# from `src/lib/sanity.ts` (the launch defaults).
# ───────────────────────────────────────────────────────────────────────────
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-05-01
SANITY_API_READ_TOKEN=
SANITY_PREVIEW_SECRET=

# Studio mount at /studio uses these client-side vars too:
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# ───────────────────────────────────────────────────────────────────────────
# Email Service Provider  (Brief §12)
# Choose ONE: ConvertKit (native double opt-in) or Resend (manual template).
# ───────────────────────────────────────────────────────────────────────────
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

RESEND_API_KEY=
RESEND_FROM=hello@athlence.com

# ───────────────────────────────────────────────────────────────────────────
# Instagram Graph API  (Brief §5.7)
# Long-lived user token (60-day expiry — rotate via your token service).
# Without these, the IG feed shows 8 placeholder gradient tiles.
# ───────────────────────────────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ───────────────────────────────────────────────────────────────────────────
# Analytics  (Brief §12)
# Plausible: privacy-friendly, no cookies. Meta Pixel: ad attribution.
# ───────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
META_PIXEL_ID=

# ───────────────────────────────────────────────────────────────────────────
# Vercel KV  (Brief §8 + §12)
# Used for: rate-limit counters on /api/signup, IG fallback cache.
# In dev without KV, the rate-limit module falls back to in-memory.
# ───────────────────────────────────────────────────────────────────────────
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ───────────────────────────────────────────────────────────────────────────
# Preview environment basic auth  (Brief §14)
# Gates *.vercel.app preview deploys. Leave blank locally.
# ───────────────────────────────────────────────────────────────────────────
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# ───────────────────────────────────────────────────────────────────────────
# Signup hardening
# Comma-separated origins permitted for /api/signup. Empty = same-origin only.
# ───────────────────────────────────────────────────────────────────────────
ALLOWED_SIGNUP_ORIGINS=
